# Copia este archivo como ".env" y pon tus valores reales.
# NUNCA subas el archivo ".env" (con tus valores reales) a git.

# Cadena de conexión de Supabase (pestaña "Session pooler")
# Formato: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.TU_REFERENCIA:TU_PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres

# Entorno actual: local | staging | production
APP_ENV=local
